{
  "manifest_version": 3,
  "name": "YT Downloader — кнопка скачивания",
  "version": "1.0.0",
  "description": "Добавляет кнопку скачивания на YouTube. Качество выбирает пользователь, скачивает локальный сервер (yt-dlp).",
  "permissions": ["storage", "downloads"],
  "host_permissions": [
    "http://127.0.0.1:5001/*",
    "https://www.youtube.com/*"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": ["https://www.youtube.com/*"],
      "js": ["content.js"],
      "css": ["content.css"],
      "run_at": "document_idle"
    }
  ],
  "action": {
    "default_popup": "popup.html",
    "default_title": "YT Downloader",
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  }
}
